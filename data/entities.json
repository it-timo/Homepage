      "title": "Architecture Is Communication",
      "slug": "architecture-is-communication",
      "collection": "articles",
      "status": "living note",
      "year": 2026,
      "date": null,
      "summary": "Architecture matters when it helps the next person understand why a system is shaped the way it is.",
